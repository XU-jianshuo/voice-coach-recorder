# Backend
APP_ENV=development
APP_NAME=Voice Coach Recorder
API_PREFIX=/api/v1
SECRET_KEY=change-me
DEVICE_TOKEN=change-me-device-token

# Database
DATABASE_URL=sqlite:///./data/voice_coach.db
# DATABASE_URL=postgresql+psycopg://voicecoach:voicecoach@postgres:5432/voicecoach

# Storage
STORAGE_DIR=./data/storage
MAX_UPLOAD_MB=200

# Queue / Redis
REDIS_URL=redis://redis:6379/0
USE_BACKGROUND_QUEUE=false

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
USE_DEEPSEEK=false

# ASR
ASR_PROVIDER=mock
FUNASR_MODEL_DIR=./models/funasr
SENSEVOICE_MODEL_DIR=./models/sensevoice
ENABLE_DIARIZATION=false

# Security
CORS_ORIGINS=*
LOG_LEVEL=INFO
